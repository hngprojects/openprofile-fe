#!/usr/bin/env sh

branch="$(git rev-parse --abbrev-ref HEAD)"
protected_branches="main dev PRODUCTION STAGING"


for protected in $protected_branches; do
  if [ "$branch" = "$protected" ]; then
    echo "❌ Pushing directly to '$branch' is not allowed."
    echo " Please open a Pull Request instead."
    exit 1
  fi
done

echo '���️  Building project...'
pnpm build ||
(
    echo '❌ Build failed!'
    echo '��� Fix the build errors above before pushing'
    echo ''
    exit 1
)

echo '✅ Build successful! Pushing to remote...'
